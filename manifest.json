{
  "manifest_version": 3,
  "name": "Exam Countdown Overlay",
  "version": "2.0.0",
  "description": "Draggable floating exam countdown on every webpage.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["exams-data.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}